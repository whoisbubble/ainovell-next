# Generic OpenAI-compatible provider variables.
AI_PROVIDER=mistral
AI_API_KEY=your_api_key
AI_MODEL=mistral-small-latest
AI_API_URL=https://api.mistral.ai/v1/chat/completions
AI_MAX_TOKENS=8192
AI_TIMEOUT_MS=120000
AI_GLOBAL_SYSTEM_PROMPT=

# Backward-compatible Mistral variables also work.
MISTRAL_API_KEY=
MISTRAL_MODEL=
MISTRAL_API_URL=
MISTRAL_MAX_TOKENS=
MISTRAL_TIMEOUT_MS=

# OpenAI-style variables also work.
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
